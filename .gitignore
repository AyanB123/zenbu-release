# Dependencies
node_modules/

# Build output
dist/
*.tsbuildinfo

# Zenbu workspace state
.zenbu/
node_modules/.zenbujs/

# Local-only TS overrides
tsconfig.local.json

# Per-developer local plugin overlay (declared via `pluginsFiles` in zenbu.config.ts).
# Lets you locally enable/disable plugins without touching the tracked manifest.
zenbu.plugins.local.jsonc

# Legacy TS overlay format — still ignored so any stale file from a previous
# checkout doesn't accidentally get committed. Inert as of the JSONC migration.
zenbu.local.ts

# Env files (keep .env.example tracked)
.env
.env.*
!.env.example

# Test coverage
coverage/
.nyc_output/

# OS junk
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Editor junk
*.swp
*.swo
*~
.idea/
*.iml


# Boot-trace dumps (one JSON per dev boot)
traces/

# Logs from `scripts/gen-plugin-icons.sh`
.icon-gen-logs/

# Startup-time experiments / benchmarks
experiments/
tmp
.vercel

# Local agent/tool state (not portable across machines)
.omx/
.firecrawl/
.patch-work/

# Machine-specific local MCP debug config (hardcoded python/cwd paths).
# Copy and edit locally; do not commit.
mcp/zenbu-debug.mcpify.json
