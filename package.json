{
  "name": "hackable-gui",
  "version": "0.0.2",
  "private": true,
  "type": "module",
  "main": "node_modules/@zenbujs/core/dist/setup-gate.mjs",
  "scripts": {
    "dev": "zen dev",
    "build:source": "zen build:source",
    "build:electron": "zen build:electron",
    "publish:source": "zen publish:source",
    "link": "zen link",
    "db:generate": "zen db generate",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "ci": "pnpm run typecheck && pnpm run lint",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@zenbujs/core": "0.2.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "electron": "^42.0.0",
    "electron-builder": "^26.0.0",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6"
  },
  "zenbu": {
    "host": ">=0.0.0 <0.1.0"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:zenbu-labs/zenbu-release.git"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "electron",
      "electron-winstaller",
      "esbuild"
    ]
  }
}
