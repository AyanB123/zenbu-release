{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "paths": {
      "@/*": [
        "./src/renderer/*"
      ],
      "#registry/*": [
        "./types/*"
      ]
    }
  },
  "include": [
    "src",
    "tests",
    "types",
    "./.zenbu/types/zenbu-register.ts"
  ]
}
