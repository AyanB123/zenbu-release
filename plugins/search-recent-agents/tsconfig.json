{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "paths": {
      "@/*": ["../app/src/renderer/*"],
      "@host/*": ["../app/src/*"],
      "#registry/*": ["../app/types/*"]
    }
  },
  "include": ["src", "zenbu.plugin.ts", "./.zenbu/types/zenbu-register.ts"]
}
